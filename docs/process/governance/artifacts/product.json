{
  "schema_version": "1.0",
  "domain": "product",
  "defaults": {
    "lifecycle": "persistent",
    "contributors": [],
    "mutable_fields": {},
    "validation_command": null
  },
  "artifacts": [
    {"artifact_id":"PRODUCT_VISION","canonical_path":"docs/product/vision.md","accountable_owner":"product-manager","applicability":"product direction or positioning changes"},
    {"artifact_id":"PRODUCT_ROADMAP","canonical_path":"docs/product/roadmap.md","accountable_owner":"product-manager","applicability":"priority or delivery horizon changes","required_direct_inputs":["PRODUCT_VISION"]},
    {"artifact_id":"DEVELOPMENT_STATUS","canonical_path":"docs/product/development_status.md","accountable_owner":"product-manager","applicability":"durable product progress changes","conditional_inputs":["IMPLEMENTATION_REPORT","TEST_REPORT"]},
    {"artifact_id":"CAPABILITY_REGISTRY","canonical_path":"docs/product/feature_registry.md","accountable_owner":"product-manager","method_skill":"capability-registry-develop","applicability":"Capability or Sub-capability facts change","validation_command":"python scripts/validate_capability_registry.py"},
    {"artifact_id":"STORY_MAP","canonical_path":"docs/product/story_map.md","accountable_owner":"product-manager","method_skill":"story-map-develop","applicability":"approved user-visible Story or Slice semantics change","required_direct_inputs":["CAPABILITY_REGISTRY"]},
    {"artifact_id":"PRODUCT_BASE_REQUIREMENTS","canonical_path":"docs/product/base/requirements.md","accountable_owner":"requirement-development","method_skill":"requirement-refine","applicability":"accepted stable requirements change","required_direct_inputs":["STORY_MAP"]},
    {"artifact_id":"PRODUCT_BASE_SPEC","canonical_path":"docs/product/base/spec.md","accountable_owner":"product-spec-authority","method_skill":"feature-spec-generate","applicability":"accepted stable behavior specification changes","required_direct_inputs":["PRODUCT_BASE_REQUIREMENTS"]},
    {"artifact_id":"PRODUCT_BASE_ACCEPTANCE","canonical_path":"docs/product/base/acceptance.md","accountable_owner":"acceptance-authority","method_skill":"acceptance-criteria-generate","applicability":"accepted stable pass/fail behavior changes","required_direct_inputs":["PRODUCT_BASE_SPEC"]},
    {"artifact_id":"PRODUCT_BASE_TRACEABILITY","canonical_path":"docs/product/base/traceability.md","accountable_owner":"traceability-authority","method_skill":"document-traceability-check","contributors":["qa"],"mutable_fields":{"qa":{"type":"markdown-table-columns","table_heading":"强制追溯矩阵","columns":["Test Evidence","Status"],"append_headings":["当前缺口"]}},"applicability":"Product Base coverage or evidence changes","required_direct_inputs":["PRODUCT_BASE_REQUIREMENTS","PRODUCT_BASE_SPEC","PRODUCT_BASE_ACCEPTANCE"]},
    {"artifact_id":"PRODUCT_BASELINE","canonical_path":"docs/product/baselines/{baseline_slug}.md","accountable_owner":"product-manager","applicability":"approved frozen snapshot is requested","conditional_inputs":["PRODUCT_BASE_REQUIREMENTS","PRODUCT_BASE_SPEC","PRODUCT_BASE_ACCEPTANCE","PRODUCT_BASE_TRACEABILITY"]},
    {"artifact_id":"STAGE_SCOPE","canonical_path":"docs/product/stages/{stage_id}.md","accountable_owner":"product-manager","applicability":"delivery horizon or committed Stage Scope changes","required_direct_inputs":["PRODUCT_ROADMAP"]},
    {"artifact_id":"INCREMENT_DEFINITION","canonical_path":"docs/product/increments/{increment_id}/definition.md","accountable_owner":"product-manager","applicability":"scoped delivery increment is approved","required_direct_inputs":["STAGE_SCOPE","CAPABILITY_REGISTRY"]},
    {"artifact_id":"INCREMENT_REQUIREMENTS","canonical_path":"docs/product/increments/{increment_id}/requirements.md","accountable_owner":"requirement-development","method_skill":"requirement-refine","applicability":"increment product requirements change","required_direct_inputs":["STORY_MAP","INCREMENT_DEFINITION"]},
    {"artifact_id":"INCREMENT_SPEC","canonical_path":"docs/product/increments/{increment_id}/spec.md","accountable_owner":"product-spec-authority","method_skill":"feature-spec-generate","applicability":"increment behavior specification changes","required_direct_inputs":["INCREMENT_REQUIREMENTS"]},
    {"artifact_id":"INCREMENT_ACCEPTANCE","canonical_path":"docs/product/increments/{increment_id}/acceptance.md","accountable_owner":"acceptance-authority","method_skill":"acceptance-criteria-generate","applicability":"increment pass/fail behavior changes","required_direct_inputs":["INCREMENT_SPEC"]},
    {"artifact_id":"INCREMENT_TEST_CASES","canonical_path":"docs/product/increments/{increment_id}/test_cases.md","accountable_owner":"test-case-development","method_skill":"test-case-generate","applicability":"committed increment implementation or QA planning","required_direct_inputs":["INCREMENT_SPEC","INCREMENT_ACCEPTANCE"]},
    {"artifact_id":"INCREMENT_TRACEABILITY","canonical_path":"docs/product/increments/{increment_id}/traceability.md","accountable_owner":"traceability-authority","method_skill":"document-traceability-check","contributors":["qa"],"mutable_fields":{"qa":{"type":"markdown-table-columns","columns":["Test Evidence","Status","Gap / Exception"],"append_headings":["QA Gap"]}},"applicability":"increment coverage or evidence changes","required_direct_inputs":["INCREMENT_DEFINITION","INCREMENT_REQUIREMENTS","INCREMENT_SPEC","INCREMENT_ACCEPTANCE","INCREMENT_TEST_CASES"]},
    {"artifact_id":"INCREMENT_SWC_ALLOCATION","canonical_path":"docs/product/increments/{increment_id}/swc_allocation.md","accountable_owner":"system-architect","applicability":"implementation impacts cross-layer, persistence, API, AI runtime, provider or reusable modules","required_direct_inputs":["INCREMENT_SPEC","INCREMENT_ACCEPTANCE"],"conditional_inputs":["SOFTWARE_COMPONENT_ARCHITECTURE","SWC_CATALOG"],"validation_command":"python scripts/check_swc_allocation.py --scope changed --base-ref {base_ref}"},
    {"artifact_id":"CHANGE_REQUEST","canonical_path":"docs/process/change_request.md","accountable_owner":"product-manager","applicability":"accepted scope or contract boundary changes"}
  ]
}
