    {"gate_id":"G-TEST","applicability":{"any":["implementation_change=true","product_behavior_change=true"]},"excludes_if":{"any":["operation=read-only","documentation_only=true"]},"risk_level":"high","machine_check":"resolve project test command from changed component","evidence_contract":{"evaluator":"qa","required_fields":["FR/Contract fast-test commands and results","VS full-chain command and result","gap or exception","exact commit SHA"],"persistence":"ephemeral by default; persist only when explicitly required","evidence_artifact_id":"TEST_REPORT"},"result_levels":["block","conditional","pass"],"exception_owner":"qa","exception_scope":"documented test gap with impact and owner","exception_expiry":"before completion or accepted release risk","evidence_command":"project://changed-component/test-command"},
    {"gate_id":"G-RELEASE","applicability":{"any":["release_requested=true","production_deploy_requested=true"]},"excludes_if":{"any":["non_production_preview=true","operation=read-only"]},"risk_level":"high","machine_check":"scripts/check_release_readiness.sh","evidence_contract":{"evaluator":"devops","required_fields":["release scope","implementation evidence","test evidence","rollback decision"],"persistence":"required for production release","evidence_artifact_id":"IMPLEMENTATION_REPORT"},"result_levels":["block","conditional","pass"],"exception_owner":"devops","exception_scope":"explicit non-production preview","exception_expiry":"end of preview","evidence_command":"scripts/check_release_readiness.sh"},
    {"gate_id":"G-ARTIFACT-VALIDATION","applicability":{"all":["artifact_change=true","impacted_artifact_has_validation_command=true"]},"excludes_if":{"any":["operation=read-only"]},"risk_level":"medium","machine_check":"resolve and run Artifact.validation_command for every impacted Artifact that declares one","evidence_contract":{"evaluator":"impacted Artifact accountable owner","required_fields":["impacted Artifact IDs","resolved validation commands","results"],"persistence":"ephemeral"},"result_levels":["block","pass"],"exception_owner":null,"exception_scope":null,"exception_expiry":null,"evidence_command":"artifact://impacted/validation_command"},
    {"gate_id":"G-INDEPENDENT-CHECK","applicability":{"any":["multi_step_product_change=true","product_object_governance_change=true","architecture_governance_change=true","software_component_governance_change=true","documentation_governance_change=true","meta_governance_change=true"]},"excludes_if":null,"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"Gate-selected independent checker","checker_selector":{"by_trigger":{"multi_step_product_change":"product-object-governance-check","product_object_governance_change":"product-object-governance-check","architecture_governance_change":"software-architecture-governance-check","software_component_governance_change":"software-architecture-governance-check","documentation_governance_change":"product-object-governance-check","meta_governance_change":"product-object-governance-check"},"by_artifact_id":{"CAPABILITY_REGISTRY":"product-object-governance-check","STORY_MAP":"product-object-governance-check","FUNCTIONAL_REQUIREMENT_CATALOG":"product-object-governance-check","TEST_CASE_CATALOG":"product-object-governance-check","TRACEABILITY":"product-object-governance-check","CROSS_CUTTING_BOUNDARY_REGISTRY":"software-architecture-governance-check","SWC_GOVERNANCE":"software-architecture-governance-check","SYSTEM_OVERVIEW":"software-architecture-governance-check","SOFTWARE_COMPONENT_ARCHITECTURE":"software-architecture-governance-check"}},"required_fields":["checked scope","changed files","validation","result","required corrections","residual risk"],"persistence":"ephemeral by default; persist only when explicitly required","evidence_artifact_id":"QUALITY_REPORT","evidence_artifact_by_artifact_id":{"CAPABILITY_REGISTRY":"PRODUCT_OBJECT_GOVERNANCE_CHECK_REPORT"}},"result_levels":["block","pass"],"exception_owner":null,"exception_scope":null,"exception_expiry":null,"evidence_command":null},
    {"gate_id":"G-DOCUMENT-LANGUAGE","applicability":{"all":["persistent_document_change=true","natural_language_content=true"]},"excludes_if":{"any":["machine_readable_only=true"]},"risk_level":"medium","machine_check":"python scripts/check_document_language.py --scope changed --include-worktree","evidence_contract":null,"result_levels":["block","conditional","pass"],"exception_owner":"documentation-governance","exception_scope":"user requests another language","exception_expiry":"current artifact","evidence_command":"python scripts/check_document_language.py --scope changed --include-worktree"},
    {"gate_id":"G-ADVISORY-LOCAL-CHANGE","applicability":{"all":["product_behavior_change=false","api_change=false","persistence_change=false","ai_runtime_change=false","release_change=false","cross_layer_change=false","provider_change=false","reusable_module_change=false","product_object_governance_change=false","architecture_governance_change=false","software_component_governance_change=false","documentation_governance_change=false","meta_governance_change=false"]},"excludes_if":{"any":["security_change=true","data_integrity_change=true","external_contract_change=true","irreversible_change=true"]},"risk_level":"low","machine_check":null,"evidence_contract":null,"result_levels":["advisory","pass"],"exception_owner":null,"exception_scope":null,"exception_expiry":null,"evidence_command":null}
