  "schema_version":"1.0",
  "short_circuit_rules":[
    {"rule_id":"SC-READ-ONLY","when":{"all":["operation=read-only","release_decision=false","external_state_change=false"]},"skip":["G-INCREMENT-SCOPE","G-FR","G-TC","G-CONTRACT","G-SWC","G-AI-SCHEMA","G-ARTIFACT-VALIDATION"],"retain":["G-INDEPENDENT-CHECK"]},
