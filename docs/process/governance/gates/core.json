{
  "schema_version":"1.0",
  "null_evidence_command_semantics":"evidence_command 仅在 evidence_contract 非空或 risk_level=low 时允许为 null。",
  "evaluation_order":["classify-impact","apply-high-risk-overrides","apply-low-risk-short-circuit","evaluate-matched-gates"],
  "short_circuit_rules":[
    {"rule_id":"SC-READ-ONLY","when":{"all":["operation=read-only","release_decision=false","external_state_change=false"]},"skip":["G-INCREMENT-SCOPE","G-SPEC","G-AC-TC","G-CONTRACT","G-SWC","G-AI-SCHEMA","G-ARTIFACT-VALIDATION"],"retain":["G-INDEPENDENT-CHECK"]},
    {"rule_id":"SC-LOCAL-NONBEHAVIOR","when":{"all":["product_behavior_change=false","api_change=false","persistence_change=false","ai_runtime_change=false","release_change=false","cross_layer_change=false","provider_change=false","reusable_module_change=false","product_object_governance_change=false","architecture_governance_change=false","software_component_governance_change=false","documentation_governance_change=false","meta_governance_change=false"]},"apply":["G-ADVISORY-LOCAL-CHANGE"],"skip":["G-PRODUCT-CLASSIFICATION","G-INCREMENT-SCOPE","G-SPEC","G-AC-TC","G-CONTRACT","G-SWC","G-AI-SCHEMA","G-RELEASE"]},
    {"rule_id":"SC-HIGH-RISK-OVERRIDE","when":{"any":["security_change=true","data_integrity_change=true","external_contract_change=true","irreversible_change=true","release_change=true"]},"effect":"matched high-risk gates override low-risk short-circuit"}
  ],
  "gates":[
    {"gate_id":"G-PRODUCT-CLASSIFICATION","applicability":{"any":["product_scope_change=true","user_visible_behavior_change=true"]},"excludes_if":{"any":["operation=read-only","product_behavior_change=false"]},"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"product-manager","required_fields":["classification","primary capability","affected capabilities","scope","non-goals"]},"result_levels":["block","conditional","pass"],"exception_owner":"product-manager","exception_scope":"explicit experiment only","exception_expiry":"end of experiment","evidence_command":null},
    {"gate_id":"G-REGISTRY","applicability":{"any":["capability_fact_change=true","subcapability_fact_change=true"]},"excludes_if":null,"risk_level":"high","machine_check":"python scripts/validate_capability_registry.py","evidence_contract":null,"result_levels":["block","pass"],"exception_owner":null,"exception_scope":null,"exception_expiry":null,"evidence_command":"python scripts/validate_capability_registry.py"},
    {"gate_id":"G-INCREMENT-SCOPE","applicability":{"all":["committed_delivery=true","product_behavior_change=true"]},"excludes_if":{"any":["operation=read-only","task_kind=experiment"]},"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"product-manager","required_fields":["active stage","covered scope IDs","primary/affected capability","scope","non-goals","required artifacts"]},"result_levels":["block","conditional","pass"],"exception_owner":"product-manager","exception_scope":"product-base consolidation or experiment","exception_expiry":"end of approved scope","evidence_command":null},
    {"gate_id":"G-SPEC","applicability":{"all":["implementation_requested=true","product_behavior_change=true"]},"excludes_if":{"any":["operation=read-only","product_behavior_change=false"]},"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"product-spec-authority","required_fields":["owning requirements","observable flows/states","failure paths","direct upstream"]},"result_levels":["block","conditional","pass"],"exception_owner":"product-manager","exception_scope":"exact bugfix with current acceptance","exception_expiry":"current change","evidence_command":null},
    {"gate_id":"G-AC-TC","applicability":{"all":["implementation_requested=true","committed_delivery=true","product_behavior_change=true"]},"excludes_if":{"any":["operation=read-only","product_behavior_change=false"]},"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"test-case-development","required_fields":["AC IDs","stable TC IDs or allowed exceptions","owner","evidence plan"]},"result_levels":["block","conditional","pass"],"exception_owner":"qa","exception_scope":"manual-verification, external-dependency or not-automatable-yet","exception_expiry":"before completion","evidence_command":null},
    {"gate_id":"G-CONTRACT","applicability":{"any":["api_change=true","persistence_change=true","ai_schema_change=true","external_contract_change=true"]},"excludes_if":{"any":["operation=read-only","contract_change=false"]},"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"system-architect","required_fields":["impacted Artifact IDs","compatibility decision","artifact validation result or documented manual check"]},"result_levels":["block","conditional","pass"],"exception_owner":"system-architect","exception_scope":"time-bounded compatibility decision","exception_expiry":"declared migration date","evidence_command":null},
    {"gate_id":"G-SWC","applicability":{"any":["cross_layer_change=true","persistence_change=true","api_change=true","ai_runtime_change=true","provider_change=true","reusable_module_change=true"]},"excludes_if":{"any":["operation=read-only","swc_impact=false"]},"risk_level":"high","machine_check":"python scripts/check_swc_allocation.py --scope changed --base-ref {base_ref}","evidence_contract":null,"result_levels":["block","conditional","pass"],"exception_owner":"system-architect","exception_scope":"N/A - no SWC impact with evidence","exception_expiry":"current change","evidence_command":"python scripts/check_swc_allocation.py --scope changed --base-ref {base_ref}"},
    {"gate_id":"G-AI-SCHEMA","applicability":{"any":["ai_output_rendered=true","ai_output_persisted=true"]},"excludes_if":{"any":["operation=read-only","llm_path=false"]},"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"ai-runtime","required_fields":["prompt contract","output schema","fallback","eval cases"]},"result_levels":["block","conditional","pass"],"exception_owner":"ai-runtime","exception_scope":"deterministic non-LLM path","exception_expiry":"current change","evidence_command":null},
    {"gate_id":"G-TEST","applicability":{"any":["implementation_change=true","product_behavior_change=true"]},"excludes_if":{"any":["operation=read-only","documentation_only=true"]},"risk_level":"high","machine_check":"resolve project test command from changed component","evidence_contract":{"evaluator":"qa","required_fields":["test command","result","gap/exception","owner"],"persistence":"ephemeral by default; persist only when explicitly required","evidence_artifact_id":"TEST_REPORT"},"result_levels":["block","conditional","pass"],"exception_owner":"qa","exception_scope":"documented test gap with impact and owner","exception_expiry":"before completion or accepted release risk","evidence_command":"project://changed-component/test-command"},
    {"gate_id":"G-RELEASE","applicability":{"any":["release_requested=true","production_deploy_requested=true"]},"excludes_if":{"any":["non_production_preview=true","operation=read-only"]},"risk_level":"high","machine_check":"scripts/check_release_readiness.sh","evidence_contract":{"evaluator":"devops","required_fields":["release scope","implementation evidence","test evidence","rollback decision"],"persistence":"required for production release","evidence_artifact_id":"IMPLEMENTATION_REPORT"},"result_levels":["block","conditional","pass"],"exception_owner":"devops","exception_scope":"explicit non-production preview","exception_expiry":"end of preview","evidence_command":"scripts/check_release_readiness.sh"},
    {"gate_id":"G-ARTIFACT-VALIDATION","applicability":{"all":["artifact_change=true","impacted_artifact_has_validation_command=true"]},"excludes_if":{"any":["operation=read-only"]},"risk_level":"medium","machine_check":"resolve and run Artifact.validation_command for every impacted Artifact that declares one","evidence_contract":{"evaluator":"impacted Artifact accountable owner","required_fields":["impacted Artifact IDs","resolved validation commands","results"],"persistence":"ephemeral"},"result_levels":["block","pass"],"exception_owner":null,"exception_scope":null,"exception_expiry":null,"evidence_command":"artifact://impacted/validation_command"},
    {"gate_id":"G-INDEPENDENT-CHECK","applicability":{"any":["multi_step_product_change=true","product_object_governance_change=true","architecture_governance_change=true","software_component_governance_change=true","documentation_governance_change=true","meta_governance_change=true"]},"excludes_if":null,"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"Gate-selected independent checker","checker_selector":{"by_trigger":{"multi_step_product_change":"product-object-governance-check","product_object_governance_change":"product-object-governance-check","architecture_governance_change":"software-architecture-governance-check","software_component_governance_change":"software-architecture-governance-check","documentation_governance_change":"product-object-governance-check","meta_governance_change":"product-object-governance-check"},"by_artifact_id":{"CAPABILITY_REGISTRY":"product-object-governance-check","STORY_MAP":"product-object-governance-check","CROSS_CUTTING_BOUNDARY_REGISTRY":"software-architecture-governance-check","SWC_GOVERNANCE":"software-architecture-governance-check","INCREMENT_SWC_ALLOCATION":"software-architecture-governance-check"}},"required_fields":["checked scope","changed files","validation","result","required corrections","residual risk"],"persistence":"ephemeral by default; persist only when explicitly required","evidence_artifact_id":"QUALITY_REPORT","evidence_artifact_by_artifact_id":{"CAPABILITY_REGISTRY":"PRODUCT_OBJECT_GOVERNANCE_CHECK_REPORT"}},"result_levels":["block","pass"],"exception_owner":null,"exception_scope":null,"exception_expiry":null,"evidence_command":null},
    {"gate_id":"G-DOCUMENT-LANGUAGE","applicability":{"all":["persistent_document_change=true","natural_language_content=true"]},"excludes_if":{"any":["machine_readable_only=true"]},"risk_level":"medium","machine_check":"python scripts/check_document_language.py --scope changed --include-worktree","evidence_contract":null,"result_levels":["block","conditional","pass"],"exception_owner":"documentation-governance","exception_scope":"user requests another language","exception_expiry":"current artifact","evidence_command":"python scripts/check_document_language.py --scope changed --include-worktree"},
    {"gate_id":"G-ADVISORY-LOCAL-CHANGE","applicability":{"all":["product_behavior_change=false","api_change=false","persistence_change=false","ai_runtime_change=false","release_change=false","cross_layer_change=false","provider_change=false","reusable_module_change=false","product_object_governance_change=false","architecture_governance_change=false","software_component_governance_change=false","documentation_governance_change=false","meta_governance_change=false"]},"excludes_if":{"any":["security_change=true","data_integrity_change=true","external_contract_change=true","irreversible_change=true"]},"risk_level":"low","machine_check":null,"evidence_contract":null,"result_levels":["advisory","pass"],"exception_owner":null,"exception_scope":null,"exception_expiry":null,"evidence_command":null}
  ]
}
