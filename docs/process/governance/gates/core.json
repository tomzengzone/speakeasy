    {"gate_id":"G-CONTRACT","applicability":{"any":["contract_fact_change=true","api_change=true","persistence_change=true","ai_schema_change=true","ux_contract_change=true","external_contract_change=true"]},"excludes_if":{"any":["operation=read-only","contract_change=false"]},"risk_level":"high","machine_check":null,"evidence_contract":{"evaluator":"system-architect","required_fields":["impacted Artifact IDs","source FR IDs","compatibility decision","Contract-TC result or documented manual check"]},"result_levels":["block","conditional","pass"],"exception_owner":"system-architect","exception_scope":"time-bounded compatibility decision","exception_expiry":"declared migration date","evidence_command":null},
